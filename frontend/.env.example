NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BEFORE_API_BASE_URL=http://localhost:8000

# Firebase Web App public config. Do not put service account JSON or secrets here.
NEXT_PUBLIC_FIREBASE_API_KEY=your-public-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-web-app-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
