DATABASE_URL=postgresql+psycopg2://placeholder
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=3
DB_POOL_TIMEOUT_SECONDS=30
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
FIREBASE_PROJECT_ID=
# Optional fallback for Firebase Admin credentials. Keep this JSON file under an ignored path.
# If GOOGLE_APPLICATION_CREDENTIALS or local ADC is available, Firebase Admin may use that ADC first,
# so this fallback path may not be used.
FIREBASE_ADMIN_CREDENTIALS=config/secrets/firebase-admin.json
VERTEX_ANSWER_MODEL=gemini-2.5-flash
# VERTEX_EMBEDDING_HARD_TIMEOUT_SECONDS=15
# VERTEX_ANSWER_HARD_TIMEOUT_SECONDS=25
# BEFORE_OCR_TIMEOUT_SECONDS=120
# BEFORE_REVIEW_JOB_STALE_TIMEOUT_SECONDS=180
# VERTEX_PROVIDER_MAX_RETRIES=2
# VERTEX_PROVIDER_RETRY_BASE_SECONDS=1
# Optional for local ADC if you use `gcloud auth application-default login`.
# GOOGLE_APPLICATION_CREDENTIALS=config/secrets/service-account.json
